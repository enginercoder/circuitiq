<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_light">

    <!-- Header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@drawable/bg_header_card"
        android:orientation="vertical"
        android:paddingStart="16dp" android:paddingEnd="16dp"
        android:paddingTop="44dp" android:paddingBottom="20dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical">
            <ImageButton android:id="@+id/btnBack"
                android:layout_width="40dp" android:layout_height="40dp"
                android:background="@drawable/bg_dark_mode_btn"
                android:src="@drawable/ic_back"
                android:contentDescription="Back"/>
            <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:orientation="vertical"
                android:layout_marginStart="12dp">
                <TextView android:id="@+id/tvTitle"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Calculator" android:textColor="#FFFFFF"
                    android:textSize="18sp" android:fontFamily="sans-serif-bold"/>
                <TextView android:id="@+id/tvCategory"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Category" android:textColor="#CCFFFFFF" android:textSize="12sp"/>
            </LinearLayout>
            <Button android:id="@+id/btnFav"
                android:layout_width="44dp" android:layout_height="44dp"
                android:text="☆" android:textSize="20sp" android:textColor="#FDCB6E"
                android:background="@drawable/bg_dark_mode_btn"
                android:padding="0dp"/>
        </LinearLayout>
        <TextView android:id="@+id/tvDesc"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="" android:textColor="#BBFFFFFF" android:textSize="12sp"
            android:layout_marginStart="52dp" android:layout_marginTop="2dp"/>
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp" android:paddingBottom="40dp">

            <!-- Input card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="20dp" app:cardElevation="3dp"
                app:cardBackgroundColor="@color/bg_card">
                <LinearLayout android:id="@+id/inputContainer"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="20dp"/>
            </com.google.android.material.card.MaterialCardView>

            <!-- Buttons -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="14dp">
                <Button android:id="@+id/btnClear"
                    android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="52dp" android:text="🗑 Clear"
                    android:textColor="@color/primary" android:layout_marginEnd="10dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:strokeColor="@color/primary" app:cornerRadius="16dp"/>
                <Button android:id="@+id/btnCalculate"
                    android:layout_width="0dp" android:layout_weight="2"
                    android:layout_height="52dp" android:text="⚡ Calculate"
                    android:textColor="#FFFFFF" android:textSize="16sp"
                    android:fontFamily="sans-serif-bold"
                    android:background="@drawable/bg_btn_primary"
                    android:stateListAnimator="@null"/>
            </LinearLayout>

            <!-- Result card -->
            <LinearLayout android:id="@+id/resultCard"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_result_dark"
                android:padding="20dp" android:layout_marginBottom="14dp"
                android:visibility="gone">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="⚡ Results" android:textColor="#FDCB6E"
                    android:textSize="15sp" android:fontFamily="sans-serif-bold"
                    android:layout_marginBottom="12dp"/>
                <TextView android:id="@+id/tvResults"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="#FFFFFF" android:textSize="16sp"
                    android:lineSpacingExtra="8dp" android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="14dp"/>
                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#33FFFFFF" android:layout_marginBottom="12dp"/>
                <TextView android:id="@+id/tvFormula"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="#A29BFE" android:textSize="13sp"
                    android:layout_marginBottom="6dp"/>
                <TextView android:id="@+id/tvExplanation"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="#9999BB" android:textSize="12sp"
                    android:lineSpacingExtra="3dp" android:layout_marginBottom="16dp"/>
                <Button android:id="@+id/btnShare"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:text="📤 Share Result"
                    android:textColor="#1A1A2E" android:fontFamily="sans-serif-bold"
                    android:background="@drawable/bg_btn_gold"
                    android:stateListAnimator="@null"/>
            </LinearLayout>

            <!-- Learning card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/learningCard"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="12dp" android:visibility="gone"
                app:cardCornerRadius="20dp" app:cardElevation="2dp"
                app:cardBackgroundColor="@color/bg_card">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="20dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🎓" android:textSize="22sp" android:layout_marginEnd="10dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Learn How It Works"
                            android:textColor="@color/primary" android:textSize="16sp"
                            android:fontFamily="sans-serif-bold"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="📌 Concept" android:textColor="@color/primary_dark"
                        android:textSize="12sp" android:fontFamily="sans-serif-bold"
                        android:layout_marginBottom="4dp"/>
                    <TextView android:id="@+id/tvConceptText"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:textColor="@color/text_primary" android:textSize="14sp"
                        android:lineSpacingExtra="4dp" android:layout_marginBottom="14dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="📋 Steps" android:textColor="@color/primary_dark"
                        android:textSize="12sp" android:fontFamily="sans-serif-bold"
                        android:layout_marginBottom="4dp"/>
                    <TextView android:id="@+id/tvStepsText"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:textColor="@color/text_primary" android:textSize="14sp"
                        android:lineSpacingExtra="4dp" android:layout_marginBottom="14dp"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:background="@drawable/bg_example_box"
                        android:padding="14dp" android:layout_marginBottom="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="💡 Example" android:textColor="@color/gold_dark"
                            android:textSize="12sp" android:fontFamily="sans-serif-bold"
                            android:layout_marginBottom="4dp"/>
                        <TextView android:id="@+id/tvExampleText"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:textColor="@color/text_primary" android:textSize="13sp"
                            android:lineSpacingExtra="3dp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:background="@drawable/bg_tip_box"
                        android:padding="14dp">
                        <TextView android:id="@+id/tvTipText"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:textColor="@color/tip_text" android:textSize="13sp"
                            android:lineSpacingExtra="3dp"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>