<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_light">

    <!-- Header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@drawable/bg_gradient_header"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingStart="8dp" android:paddingEnd="16dp"
        android:paddingTop="40dp" android:paddingBottom="16dp">
        <ImageButton android:id="@+id/btnBack"
            android:layout_width="44dp" android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back" android:contentDescription="Back"/>
        <LinearLayout android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="wrap_content" android:orientation="vertical"
            android:layout_marginStart="8dp">
            <TextView android:id="@+id/tvTitle"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Calculator" android:textColor="#FFD700"
                android:textSize="18sp" android:fontFamily="sans-serif-bold"/>
            <TextView android:id="@+id/tvCategory"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Category" android:textColor="#CCFFFFFF" android:textSize="12sp"/>
        </LinearLayout>
        <Button android:id="@+id/btnFav"
            android:layout_width="44dp" android:layout_height="44dp"
            android:text="☆" android:textSize="20sp" android:textColor="#FFD700"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="0dp"/>
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp" android:paddingBottom="80dp">

            <!-- Inputs -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp" app:cardElevation="4dp">
                <LinearLayout android:id="@+id/inputContainer"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="20dp"/>
            </com.google.android.material.card.MaterialCardView>

            <!-- Action buttons -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="16dp">
                <Button android:id="@+id/btnClear"
                    android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="52dp" android:text="Clear"
                    android:textColor="@color/primary" android:layout_marginEnd="8dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:strokeColor="@color/primary" app:cornerRadius="14dp"/>
                <Button android:id="@+id/btnCalculate"
                    android:layout_width="0dp" android:layout_weight="2"
                    android:layout_height="52dp" android:text="⚡ Calculate"
                    android:textColor="@color/text_primary" android:textSize="16sp"
                    android:fontFamily="sans-serif-bold"
                    android:background="@drawable/bg_btn_gold"
                    android:stateListAnimator="@null"/>
            </LinearLayout>

            <!-- Result Card -->
            <LinearLayout android:id="@+id/resultCard"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_result_card"
                android:padding="20dp" android:visibility="gone">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Results" android:textColor="#FFD700"
                    android:textSize="14sp" android:fontFamily="sans-serif-bold"
                    android:layout_marginBottom="12dp"/>
                <TextView android:id="@+id/tvResults"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="" android:textColor="#FFFFFF"
                    android:textSize="16sp" android:lineSpacingExtra="6dp"
                    android:fontFamily="sans-serif-medium" android:layout_marginBottom="16dp"/>
                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#33FFFFFF" android:layout_marginBottom="12dp"/>
                <TextView android:id="@+id/tvFormula"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="" android:textColor="#CE93D8"
                    android:textSize="13sp" android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="8dp"/>
                <TextView android:id="@+id/tvExplanation"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="" android:textColor="#AAAACC"
                    android:textSize="12sp" android:layout_marginBottom="16dp"/>
                <Button android:id="@+id/btnShare"
                    android:layout_width="match_parent" android:layout_height="44dp"
                    android:text="  Share Result"
                    android:textColor="#1A0A2E" android:fontFamily="sans-serif-bold"
                    android:background="@drawable/bg_btn_gold"
                    android:stateListAnimator="@null"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>