<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Glow ring -->
    <View android:id="@+id/glowRing"
        android:layout_width="220dp" android:layout_height="220dp"
        android:background="@drawable/bg_glow_circle"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/tvSplashName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        android:layout_marginBottom="24dp"
        android:alpha="0"/>

    <!-- App Icon - round cropped -->
    <ImageView android:id="@+id/ivSplashIcon"
        android:layout_width="160dp" android:layout_height="160dp"
        android:src="@mipmap/ic_launcher_round"
        android:scaleType="fitCenter"
        app:layout_constraintTop_toTopOf="@+id/glowRing"
        app:layout_constraintBottom_toBottomOf="@+id/glowRing"
        app:layout_constraintStart_toStartOf="@+id/glowRing"
        app:layout_constraintEnd_toEndOf="@+id/glowRing"
        android:alpha="0"/>

    <!-- App Name -->
    <TextView android:id="@+id/tvSplashName"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="CircuitIQ"
        android:textColor="#FFD700"
        android:textSize="44sp"
        android:fontFamily="sans-serif-bold"
        android:letterSpacing="0.05"
        android:alpha="0"
        android:layout_marginBottom="8dp"
        app:layout_constraintTop_toBottomOf="@+id/glowRing"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/tvSplashTagline"/>

    <!-- Tagline -->
    <TextView android:id="@+id/tvSplashTagline"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Smart Electrical Calculator"
        android:textColor="#AAAACC" android:textSize="15sp"
        android:letterSpacing="0.06" android:alpha="0"
        android:layout_marginBottom="28dp"
        app:layout_constraintTop_toBottomOf="@+id/tvSplashName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/badgeRow"/>

    <!-- Feature badges -->
    <LinearLayout android:id="@+id/badgeRow"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:orientation="horizontal" android:alpha="0"
        app:layout_constraintTop_toBottomOf="@+id/tvSplashTagline"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="⚡ 48 Calculators" android:textColor="#CCFFD700" android:textSize="12sp"
            android:background="@drawable/bg_splash_badge"
            android:paddingStart="12dp" android:paddingEnd="12dp"
            android:paddingTop="6dp" android:paddingBottom="6dp" android:layout_marginEnd="8dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="📴 Offline" android:textColor="#CCFFD700" android:textSize="12sp"
            android:background="@drawable/bg_splash_badge"
            android:paddingStart="12dp" android:paddingEnd="12dp"
            android:paddingTop="6dp" android:paddingBottom="6dp" android:layout_marginEnd="8dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="🆓 Free" android:textColor="#CCFFD700" android:textSize="12sp"
            android:background="@drawable/bg_splash_badge"
            android:paddingStart="12dp" android:paddingEnd="12dp"
            android:paddingTop="6dp" android:paddingBottom="6dp"/>
    </LinearLayout>

    <!-- Author -->
    <TextView android:id="@+id/tvSplashAuthor"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="by Aditya Pal · EEE Engineer"
        android:textColor="#555577" android:textSize="12sp" android:alpha="0"
        android:layout_marginBottom="72dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Three dot loader -->
    <LinearLayout android:id="@+id/dotLoader"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center"
        android:layout_marginBottom="32dp" android:alpha="0"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <View android:id="@+id/dot1"
            android:layout_width="10dp" android:layout_height="10dp"
            android:background="@drawable/bg_dot" android:layout_marginEnd="8dp"/>
        <View android:id="@+id/dot2"
            android:layout_width="10dp" android:layout_height="10dp"
            android:background="@drawable/bg_dot" android:layout_marginEnd="8dp"/>
        <View android:id="@+id/dot3"
            android:layout_width="10dp" android:layout_height="10dp"
            android:background="@drawable/bg_dot"/>
    </LinearLayout>

    <!-- Gold bottom bar -->
    <View android:layout_width="match_parent" android:layout_height="3dp"
        android:background="@drawable/bg_gold_bar"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>