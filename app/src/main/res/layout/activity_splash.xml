<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Glow circle behind icon -->
    <View android:layout_width="280dp" android:layout_height="280dp"
        android:background="@drawable/bg_glow_circle"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="80dp"/>

    <!-- App Icon (real PNG) -->
    <ImageView android:id="@+id/ivSplashIcon"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:src="@mipmap/ic_launcher"
        android:scaleType="fitCenter"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="120dp"
        app:layout_constraintVertical_chainStyle="packed"/>

    <!-- App Name -->
    <TextView android:id="@+id/tvSplashName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CircuitIQ"
        android:textColor="#FFD700"
        android:textSize="48sp"
        android:fontFamily="sans-serif-bold"
        android:letterSpacing="0.05"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@+id/ivSplashIcon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Tagline -->
    <TextView android:id="@+id/tvSplashTagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Smart Electrical Calculator"
        android:textColor="#AAAACC"
        android:textSize="16sp"
        android:letterSpacing="0.08"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@+id/tvSplashName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Feature badges row -->
    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@+id/tvSplashTagline"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="40+ Calculators" android:textColor="#CCFFD700"
            android:textSize="12sp" android:background="@drawable/bg_splash_badge"
            android:paddingStart="12dp" android:paddingEnd="12dp"
            android:paddingTop="6dp" android:paddingBottom="6dp"
            android:layout_marginEnd="8dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="100% Offline" android:textColor="#CCFFD700"
            android:textSize="12sp" android:background="@drawable/bg_splash_badge"
            android:paddingStart="12dp" android:paddingEnd="12dp"
            android:paddingTop="6dp" android:paddingBottom="6dp"
            android:layout_marginEnd="8dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Free Forever" android:textColor="#CCFFD700"
            android:textSize="12sp" android:background="@drawable/bg_splash_badge"
            android:paddingStart="12dp" android:paddingEnd="12dp"
            android:paddingTop="6dp" android:paddingBottom="6dp"/>
    </LinearLayout>

    <!-- Author -->
    <TextView android:id="@+id/tvSplashAuthor"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="by Aditya Pal · EEE Engineer"
        android:textColor="#666688"
        android:textSize="13sp"
        android:layout_marginBottom="48dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Gold bottom bar -->
    <View android:layout_width="match_parent" android:layout_height="3dp"
        android:background="@drawable/bg_gold_bar"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>