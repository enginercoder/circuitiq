<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_light">

    <!-- Header Card - like reference "Hello, Name!" style -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@drawable/bg_header_card"
        android:orientation="vertical"
        android:paddingStart="24dp" android:paddingEnd="20dp"
        android:paddingTop="44dp" android:paddingBottom="28dp">

        <!-- Top row: greeting + dark mode button -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <!-- Greeting icon - single icon based on time -->
            <TextView android:id="@+id/tvGreetingIcon"
                android:layout_width="44dp" android:layout_height="44dp"
                android:text="☀️" android:textSize="24sp" android:gravity="center"
                android:background="@drawable/bg_greeting_icon"
                android:layout_marginEnd="12dp"/>

            <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:orientation="vertical">
                <TextView android:id="@+id/tvGreeting"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Good Morning!" android:textColor="#FFFFFF"
                    android:textSize="22sp" android:fontFamily="sans-serif-bold"/>
                <TextView android:id="@+id/tvSubtitle"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="What will you calculate?" android:textColor="#CCFFFFFF"
                    android:textSize="13sp" android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- Dark mode + fav count -->
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:id="@+id/tvFavCount"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0 ★" android:textColor="#FDCB6E"
                    android:textSize="13sp" android:fontFamily="sans-serif-bold"
                    android:background="@drawable/bg_dark_mode_btn"
                    android:paddingStart="10dp" android:paddingEnd="10dp"
                    android:paddingTop="6dp" android:paddingBottom="6dp"
                    android:layout_marginEnd="8dp"/>
                <ImageButton android:id="@+id/btnDarkMode"
                    android:layout_width="40dp" android:layout_height="40dp"
                    android:background="@drawable/bg_dark_mode_btn"
                    android:src="@drawable/ic_dark_mode"
                    android:tint="#FFFFFF"
                    android:contentDescription="Dark mode"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Search bar -->
        <EditText android:id="@+id/etSearch"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:hint="🔍  Search 48+ calculators..."
            android:background="@drawable/bg_search_field"
            android:paddingStart="18dp" android:paddingEnd="18dp"
            android:textSize="14sp" android:textColor="@color/text_primary"
            android:textColorHint="#9999BB"
            android:inputType="text" android:imeOptions="actionSearch"/>
    </LinearLayout>

    <!-- Category pills row -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCategories"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:paddingStart="16dp" android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:clipToPadding="false"/>

    <!-- Share + Request row -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp" android:paddingEnd="16dp"
        android:paddingTop="4dp" android:paddingBottom="4dp">
        <Button android:id="@+id/btnShareApp"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="38dp"
            android:text="📤 Share App" android:textSize="12sp"
            android:textColor="#FFFFFF" android:fontFamily="sans-serif-bold"
            android:background="@drawable/bg_share_btn"
            android:stateListAnimator="@null"
            android:layout_marginEnd="8dp"/>
        <Button android:id="@+id/btnRequestFeature"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="38dp"
            android:text="💡 Request Feature" android:textSize="12sp"
            android:textColor="#FFFFFF" android:fontFamily="sans-serif-bold"
            android:background="@drawable/bg_request_btn"
            android:stateListAnimator="@null"/>
    </LinearLayout>

    <!-- Section title -->
    <TextView android:id="@+id/tvSectionTitle"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="All Calculators (48)"
        android:textSize="16sp" android:fontFamily="sans-serif-bold"
        android:textColor="@color/text_primary"
        android:paddingStart="20dp" android:paddingEnd="16dp"
        android:paddingTop="8dp" android:paddingBottom="4dp"/>

    <!-- Calculators grid -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCalculators"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingStart="12dp" android:paddingEnd="12dp"
        android:paddingBottom="80dp" android:clipToPadding="false"/>

</LinearLayout>